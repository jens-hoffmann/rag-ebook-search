# PostgreSQL (for compose.yaml)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=rag_ebooks

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rag_ebooks

# LMStudio OpenAI-compatible API
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# Models served by LMStudio
EMBEDDING_MODEL=text-embedding-embeddinggemma-300m-qat
LLM_MODEL=qwen3.5-9b

# Document chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
